[auth]
user = ""
password = ""
totp_serial = ""
totp_secret = ""
use_keyring = false
keyring_store_totp_secret = false

[paths]
# Relative paths in this file resolve from this config file's directory.
sync_directory = "./"
cookie_file = "" # Defaults to the user config directory, e.g. ~/.config/syncmymoodle/session on Linux
browser = ""

[courses]
selected = []
skip = []
semesters = []
prefix_handling = "suffix"

[downloads]
update_files = true
conflict_handling = "rename"

[filters]
max_file_size = ""
min_file_size = ""
exclude_filetypes = []
exclude_files = []
exclude_links = []
allowed_domains = []
exclude_sections = []
exclude_modules = []

[links]
follow_links = true
youtube = true
opencast = true
sciebo = true

[modules]
assignment = true
resource = true
folder = true
quiz = "html"
